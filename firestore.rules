rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Caller must be authenticated AND signed in with a solidaridadnetwork.org
    // email. The auth side already enforces this via Google Workspace `hd` and
    // an email-domain check, but rules are the last line of defence.
    function signedInSolidaridad() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@solidaridadnetwork[.]org$');
    }

    // Role helpers. Looks up the caller's role on /users/{uid}. Missing field
    // is treated as 'learner' (the default for any new account).
    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.get('role', 'learner');
    }
    function isAdmin() {
      return signedInSolidaridad() && callerRole() == 'admin';
    }
    function isManagerOrAdmin() {
      return signedInSolidaridad() && callerRole() in ['manager', 'admin'];
    }

    // --- /users/{uid} ---------------------------------------------------------
    // Owner can read/write their own profile. Managers and admins can read
    // any profile (needed for the admin dashboard user table). Only admins
    // can change someone else's role; learners and managers cannot self-promote.
    match /users/{uid} {
      allow read: if signedInSolidaridad()
        && (request.auth.uid == uid || isManagerOrAdmin());

      // Owner can update their own profile, but NOT their own role (only
      // admins can change roles, including on their own doc).
      allow create: if signedInSolidaridad() && request.auth.uid == uid;
      allow update: if signedInSolidaridad() && (
        (request.auth.uid == uid
          && (!('role' in request.resource.data.diff(resource.data).affectedKeys())))
        || isAdmin()
      );
      allow delete: if false;

      // Per-course progress (one doc per course id). Owner writes, managers
      // and admins read for analytics.
      match /progress/{courseId} {
        allow read: if signedInSolidaridad()
          && (request.auth.uid == uid || isManagerOrAdmin());
        allow write: if signedInSolidaridad() && request.auth.uid == uid;
      }

      // Certificates are write-once: created on first 100% completion,
      // never updated or deleted (immutable audit trail). Managers and
      // admins can read for reporting.
      match /certificates/{courseId} {
        allow read: if signedInSolidaridad()
          && (request.auth.uid == uid || isManagerOrAdmin());
        allow create: if signedInSolidaridad() && request.auth.uid == uid;
        allow update, delete: if false;
      }
    }

    // --- /assignments/{assignmentId} ------------------------------------------
    // Required-course assignments. Managers and admins can create/delete;
    // the assigned learner can read their own assignments to surface the
    // "Required for you" section.
    match /assignments/{assignmentId} {
      allow read: if signedInSolidaridad() && (
        isManagerOrAdmin()
        || resource.data.userId == request.auth.uid
      );
      allow create: if isManagerOrAdmin()
        && request.resource.data.assignedBy == request.auth.uid;
      allow update, delete: if isManagerOrAdmin();
    }

    // --- /forum/{threadId} ----------------------------------------------------
    // Shared community forum. Any signed-in Solidaridad user can read.
    // A user can only create a thread/reply under their own uid (no forgery),
    // and only the author can edit or delete their own posts.
    match /forum/{threadId} {
      allow read: if signedInSolidaridad();

      allow create: if signedInSolidaridad()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.replyCount == 0;

      // Author can update any field on their own thread (edit title/body).
      // Any signed-in user may bump replyCount by exactly +1 and refresh
      // lastReplyAt — this is what the batched reply-write does so the
      // thread row in the list shows up-to-date counts. The +1 invariant
      // means a malicious user can't decrement, zero, or arbitrarily
      // inflate the counter.
      allow update: if signedInSolidaridad() && (
        resource.data.authorUid == request.auth.uid
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['replyCount', 'lastReplyAt'])
          && request.resource.data.replyCount == resource.data.replyCount + 1
        )
      );

      allow delete: if signedInSolidaridad()
        && resource.data.authorUid == request.auth.uid;

      match /replies/{replyId} {
        allow read: if signedInSolidaridad();

        allow create: if signedInSolidaridad()
          && request.resource.data.authorUid == request.auth.uid;

        allow update, delete: if signedInSolidaridad()
          && resource.data.authorUid == request.auth.uid;
      }
    }
  }
}
