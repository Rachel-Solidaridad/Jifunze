rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Caller must be authenticated AND signed in with a solidaridadnetwork.org
    // email. The auth side already enforces this via Google Workspace `hd` and
    // an email-domain check, but rules are the last line of defence.
    function signedInSolidaridad() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@solidaridadnetwork[.]org$');
    }

    // Role helpers. Looks up the caller's role on /users/{uid}. Missing field
    // is treated as 'learner' (the default for any new account).
    function callerRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid))
        .data.get('role', 'learner');
    }
    function isAdmin() {
      return signedInSolidaridad() && callerRole() == 'admin';
    }
    function isManagerOrAdmin() {
      return signedInSolidaridad() && callerRole() in ['manager', 'admin'];
    }

    // Seed admins are hardcoded by email. They may self-promote to 'admin'
    // on sign-in (used to bootstrap the first admins and to upgrade users
    // who pre-existed before being added to the seed list). Keep this list
    // in sync with SEED_ADMINS in src/auth/roles.js.
    function isSeedAdminEmail() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email in [
          'rachel.wanyoike@solidaridadnetwork.org',
          'digital.eca@solidaridadnetwork.org'
        ];
    }

    // --- /users/{uid} ---------------------------------------------------------
    // Owner can read/write their own profile. Managers and admins can read
    // any profile (needed for the admin dashboard user table). Only admins
    // can change someone else's role; learners and managers cannot self-promote.
    match /users/{uid} {
      allow read: if signedInSolidaridad()
        && (request.auth.uid == uid || isManagerOrAdmin());

      // Owner can update their own profile, but NOT their own role —
      // except a seed-admin email may set its own role to 'admin' (this
      // is the bootstrap path). Anything else role-related requires admin.
      allow create: if signedInSolidaridad() && request.auth.uid == uid;
      allow update: if signedInSolidaridad() && (
        (request.auth.uid == uid && (
          !('role' in request.resource.data.diff(resource.data).affectedKeys())
          || (isSeedAdminEmail() && request.resource.data.role == 'admin')
        ))
        || isAdmin()
      );
      allow delete: if false;

      // Per-course progress (one doc per course id). Owner writes, managers
      // and admins read for analytics.
      match /progress/{courseId} {
        allow read: if signedInSolidaridad()
          && (request.auth.uid == uid || isManagerOrAdmin());
        allow write: if signedInSolidaridad() && request.auth.uid == uid;
      }

      // Certificates are write-once: created on first 100% completion,
      // never updated or deleted (immutable audit trail). Managers and
      // admins can read for reporting.
      match /certificates/{courseId} {
        allow read: if signedInSolidaridad()
          && (request.auth.uid == uid || isManagerOrAdmin());
        allow create: if signedInSolidaridad() && request.auth.uid == uid;
        allow update, delete: if false;
      }

      // Achievements (badges) are also write-once: created when a learner
      // becomes eligible (course-completion, mastery, cluster, master,
      // milestone). Same shape as certificates; same audit-trail property.
      match /achievements/{achievementId} {
        allow read: if signedInSolidaridad()
          && (request.auth.uid == uid || isManagerOrAdmin());
        allow create: if signedInSolidaridad() && request.auth.uid == uid;
        allow update, delete: if false;
      }
    }

    // --- /assignments/{assignmentId} ------------------------------------------
    // Required-course assignments. Managers and admins can create/delete;
    // the assigned learner can read their own assignments to surface the
    // "Required for you" section.
    match /assignments/{assignmentId} {
      allow read: if signedInSolidaridad() && (
        isManagerOrAdmin()
        || resource.data.userId == request.auth.uid
      );
      allow create: if isManagerOrAdmin()
        && request.resource.data.assignedBy == request.auth.uid;
      allow update, delete: if isManagerOrAdmin();
    }

    // --- /forum/{threadId} ----------------------------------------------------
    // Shared community forum. Any signed-in Solidaridad user can read.
    // A user can only create a thread/reply under their own uid (no forgery),
    // and only the author can edit or delete their own posts.
    match /forum/{threadId} {
      allow read: if signedInSolidaridad();

      allow create: if signedInSolidaridad()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.replyCount == 0;

      // Author can update any field on their own thread (edit title/body).
      // Any signed-in user may bump replyCount by exactly +1 and refresh
      // lastReplyAt — this is what the batched reply-write does so the
      // thread row in the list shows up-to-date counts. The +1 invariant
      // means a malicious user can't decrement, zero, or arbitrarily
      // inflate the counter.
      allow update: if signedInSolidaridad() && (
        resource.data.authorUid == request.auth.uid
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['replyCount', 'lastReplyAt'])
          && request.resource.data.replyCount == resource.data.replyCount + 1
        )
      );

      allow delete: if signedInSolidaridad()
        && resource.data.authorUid == request.auth.uid;

      match /replies/{replyId} {
        allow read: if signedInSolidaridad();

        allow create: if signedInSolidaridad()
          && request.resource.data.authorUid == request.auth.uid;

        allow update, delete: if signedInSolidaridad()
          && resource.data.authorUid == request.auth.uid;
      }
    }

    // --- /polls/{pollId} -------------------------------------------------------
    // Flash polls. Managers/admins author them (counters seeded to 0). Any signed-in
    // user may cast ONE vote: the vote bumps exactly one option count and total by +1
    // (mirrors the forum replyCount +1 invariant). The paired write-once voter doc
    // (below, keyed by uid) is what makes a second vote fail in the atomic batch.
    // Totals are tamper-resistant, not tamper-proof — a hand-crafted request could
    // bump a counter without the voter doc, same accepted posture as forum replyCount.
    match /polls/{pollId} {
      allow read: if signedInSolidaridad();

      allow create: if isManagerOrAdmin()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.total == 0;

      allow update: if signedInSolidaridad() && (
        isManagerOrAdmin()
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['countA', 'countB', 'countC', 'countD', 'total'])
          && request.resource.data.total == resource.data.total + 1
          && (
            request.resource.data.countA == resource.data.countA + 1 ||
            request.resource.data.countB == resource.data.countB + 1 ||
            request.resource.data.countC == resource.data.countC + 1 ||
            request.resource.data.countD == resource.data.countD + 1
          )
        )
      );

      allow delete: if isManagerOrAdmin();

      // Public (to signed-in users) so it powers real participant avatars;
      // doc id is the voter's uid and is write-once → one vote per user.
      match /voters/{voterUid} {
        allow read: if signedInSolidaridad();
        allow create: if signedInSolidaridad() && voterUid == request.auth.uid
          && request.resource.data.choice in ['A', 'B', 'C', 'D'];
        allow update, delete: if false;
      }
    }

    // --- /debates/{debateId} ---------------------------------------------------
    // Micro-debates. Managers/admins author them. Any signed-in user may take ONE
    // side (bumps that side + total by +1) and post arguments (bumps argumentCount
    // by +1). The write-once voter doc enforces one stance per user.
    match /debates/{debateId} {
      allow read: if signedInSolidaridad();

      allow create: if isManagerOrAdmin()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.total == 0
        && request.resource.data.argumentCount == 0;

      allow update: if signedInSolidaridad() && (
        isManagerOrAdmin()
        || (
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['proCount', 'conCount', 'total'])
          && request.resource.data.total == resource.data.total + 1
          && (
            request.resource.data.proCount == resource.data.proCount + 1 ||
            request.resource.data.conCount == resource.data.conCount + 1
          )
        )
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['argumentCount'])
          && request.resource.data.argumentCount == resource.data.argumentCount + 1
        )
      );

      allow delete: if isManagerOrAdmin();

      match /voters/{voterUid} {
        allow read: if signedInSolidaridad();
        allow create: if signedInSolidaridad() && voterUid == request.auth.uid
          && request.resource.data.side in ['pro', 'con'];
        allow update, delete: if false;
      }

      // Arguments require the author to have already committed a side, and the
      // argument's side must match that committed stance (defence-in-depth; the
      // client also gates the composer on holding a stance).
      match /arguments/{argId} {
        allow read: if signedInSolidaridad();
        allow create: if signedInSolidaridad()
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.side ==
             get(/databases/$(database)/documents/debates/$(debateId)/voters/$(request.auth.uid)).data.side;
        allow update, delete: if signedInSolidaridad()
          && resource.data.authorUid == request.auth.uid;
      }
    }
  }
}
