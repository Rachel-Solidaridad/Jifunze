rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Caller must be authenticated AND signed in with a solidaridadnetwork.org
    // email. The auth side already enforces this via Google Workspace `hd` and
    // an email-domain check, but rules are the last line of defence.
    function signedInSolidaridad() {
      return request.auth != null
        && request.auth.token.email is string
        && request.auth.token.email.matches('.*@solidaridadnetwork[.]org$');
    }

    // --- /users/{uid} ---------------------------------------------------------
    // Profile + per-user subcollections. Only the owner can read or write.
    match /users/{uid} {
      allow read, write: if signedInSolidaridad() && request.auth.uid == uid;

      // Per-course progress (one doc per course id).
      match /progress/{courseId} {
        allow read, write: if signedInSolidaridad() && request.auth.uid == uid;
      }

      // Certificates are write-once: created on first 100% completion,
      // never updated or deleted (immutable audit trail).
      match /certificates/{courseId} {
        allow read:           if signedInSolidaridad() && request.auth.uid == uid;
        allow create:         if signedInSolidaridad() && request.auth.uid == uid;
        allow update, delete: if false;
      }
    }

    // --- /forum/{threadId} ----------------------------------------------------
    // Shared community forum. Any signed-in Solidaridad user can read.
    // A user can only create a thread/reply under their own uid (no forgery),
    // and only the author can edit or delete their own posts.
    match /forum/{threadId} {
      allow read: if signedInSolidaridad();

      allow create: if signedInSolidaridad()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.replyCount == 0;

      allow update: if signedInSolidaridad()
        && resource.data.authorUid == request.auth.uid;

      allow delete: if signedInSolidaridad()
        && resource.data.authorUid == request.auth.uid;

      match /replies/{replyId} {
        allow read: if signedInSolidaridad();

        allow create: if signedInSolidaridad()
          && request.resource.data.authorUid == request.auth.uid;

        allow update, delete: if signedInSolidaridad()
          && resource.data.authorUid == request.auth.uid;
      }
    }
  }
}
